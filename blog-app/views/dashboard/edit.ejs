<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet"/>

<main class="dashboard-page">
  <div class="container container-narrow">
    <%- include('../partials/flash') %>

    <div class="form-page-header">
      <a href="/dashboard" class="back-link"><i class="fa-solid fa-arrow-left"></i> Back to Dashboard</a>
      <h1>Edit Post</h1>
    </div>

    <form action="/dashboard/posts/<%= post._id %>?_method=PUT" method="POST"
          enctype="multipart/form-data" class="post-form" id="postForm">

      <div class="form-group">
        <label>Post Title <span class="req">*</span></label>
        <input type="text" name="title" value="<%= post.title %>" required maxlength="150"/>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Category <span class="req">*</span></label>
          <select name="category" required>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= post.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group">
          <label>Status</label>
          <select name="status">
            <option value="published" <%= post.status === 'published' ? 'selected' : '' %>>Published</option>
            <option value="draft"     <%= post.status === 'draft'     ? 'selected' : '' %>>Draft</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>Tags</label>
        <input type="text" name="tags" value="<%= post.tags.join(', ') %>"/>
      </div>

      <div class="form-group">
        <label>Cover Image <span class="hint">(leave blank to keep current)</span></label>
        <div class="current-image">
          <img src="/uploads/<%= post.coverImage %>"
               onerror="this.src='/img/default-cover.jpg'"
               alt="Current Cover" class="current-cover-thumb" loading="lazy"/>
          <span>Current image</span>
        </div>
        <div class="file-drop-zone" id="dropZone">
          <i class="fa-solid fa-cloud-arrow-up"></i>
          <p>Upload new image to replace <span>browse</span></p>
          <small>JPG, PNG, GIF, WebP — Max 5MB</small>
          <input type="file" name="image" id="imageInput" accept="image/*"/>
        </div>
      </div>

      <div class="form-group">
        <label>Content <span class="req">*</span></label>
        <div id="quillEditor" style="min-height:350px"></div>
        <textarea name="content" id="contentTextarea" style="display:none"><%= post.content %></textarea>
      </div>

      <div class="form-actions">
        <a href="/dashboard" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-floppy-disk"></i> Save Changes
        </button>
      </div>
    </form>
  </div>
</main>

<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script>
  const quill = new Quill('#quillEditor', {
    theme: 'snow',
    modules: {
      toolbar: [
        [{ header: [1,2,3,false] }],
        ['bold','italic','underline','strike'],
        [{ list: 'ordered' },{ list: 'bullet' }],
        ['blockquote','code-block'],
        ['link','image'],
        [{ align: [] }],
        ['clean'],
      ],
    },
  });

  quill.root.innerHTML = document.getElementById('contentTextarea').value;

  document.getElementById('postForm').addEventListener('submit', () => {
    document.getElementById('contentTextarea').value = quill.root.innerHTML;
  });

  document.getElementById('imageInput').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (ev) => {
      document.querySelector('.current-cover-thumb').src = ev.target.result;
    };
    reader.readAsDataURL(file);
  });
</script>
<%- include('../partials/footer') %>
